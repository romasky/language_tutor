# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ─── Anthropic (Claude API) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── OpenAI (Whisper STT) ────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── ElevenLabs TTS ──────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=english_bot
POSTGRES_USER=bot_user
POSTGRES_PASSWORD=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── n8n ─────────────────────────────────────────────────────────────────────
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=https
# Replace with your actual domain, e.g. https://bot.example.com/
N8N_WEBHOOK_URL=https://YOURDOMAIN.COM/
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=

# ─── DigitalOcean Spaces (S3-compatible) ─────────────────────────────────────
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=english-bot-audio
DO_SPACES_REGION=fra1
DO_SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com

# ─── Admin Telegram (error notifications) ────────────────────────────────────
ADMIN_TELEGRAM_CHAT_ID=
